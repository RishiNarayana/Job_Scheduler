{
  "openapi": "3.0.3",
  "info": {
    "title": "Codity Job Scheduler API",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "API is healthy"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "summary": "Login",
        "responses": {
          "200": {
            "description": "Successful login"
          }
        }
      }
    },
    "/api/v1/jobs": {
      "post": {
        "summary": "Create a job",
        "responses": {
          "201": {
            "description": "Job created"
          }
        }
      }
    }
  }
}
